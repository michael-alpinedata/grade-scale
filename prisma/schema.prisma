generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "diagramme.svg"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Subject {
  id        String     @id @default(uuid())
  name      String
  code      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  questions Question[]
}

model Question {
  id          String       @id @default(uuid())
  title       String
  content     String
  subjectId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  solution    String?
  subject     Subject      @relation(fields: [subjectId], references: [id])
  rubrics     Rubric[]
  submissions Submission[]
}

model Rubric {
  id         String      @id @default(uuid())
  title      String
  questionId String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  criteria   Criterion[]
  question   Question    @relation(fields: [questionId], references: [id])
}

model Criterion {
  id          String                @id @default(uuid())
  name        String
  description String?
  maxScore    Float
  step        Float                 @default(0.25)
  rubricId    String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  rubric      Rubric                @relation(fields: [rubricId], references: [id])
  evaluations CriterionEvaluation[]
}

model Submission {
  id              String               @id @default(uuid())
  studentPseudoId String
  content         String?
  questionId      String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  imageUrl        String?
  sourceType      SubmissionSourceType @default(TEXT)
  evaluation      Evaluation?
  question        Question             @relation(fields: [questionId], references: [id])
}

model Evaluation {
  id                  String                @id @default(uuid())
  status              EvaluationStatus      @default(PENDING)
  submissionId        String                @unique
  totalScore          Float?
  generalFeedback     String?
  misconceptions      String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  criteriaEvaluations CriterionEvaluation[]
  submission          Submission            @relation(fields: [submissionId], references: [id])
}

model CriterionEvaluation {
  id             String     @id @default(uuid())
  evaluationId   String
  criterionId    String
  score          Float
  feedback       String?
  misconceptions String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  criterion      Criterion  @relation(fields: [criterionId], references: [id])
  evaluation     Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, criterionId])
}

enum EvaluationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SubmissionSourceType {
  TEXT
  IMAGE
}

