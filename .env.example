# --- LLM Groq ---
GROQ_API_KEY="YOUR_GROQ_LLM_KEY"
GROQ_BASE_URL="https://api.groq.com/openai/v1"

# --- Database ---
# OPTION A: Local (Docker)
# Standard connection string for the local postgres container
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/grade_scale?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/grade_scale?schema=public"

# OPTION B: Cloud Azure (Industrial)
# The DATABASE_URL is automatically handled by Terraform and injected into Azure Key Vault.
# You only need to define the admin password you want for the Azure PostgreSQL instance.
AZURE_DB_PASSWORD="YOUR_AZURE_DB_ADMIN_PASSWORD"

# --- Infrastructure & CI/CD ---
# Used by Terraform and Makefile for Azure deployments and GHCR image publishing
GITHUB_USERNAME="YOUR_GITHUB_USERNAME"

# GITHUB_PAT is required to push images to GHCR (write:packages) 
# and for Azure Container Apps to pull them (read:packages).
# Scopes required: write:packages, read:packages
GITHUB_PAT="YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"
